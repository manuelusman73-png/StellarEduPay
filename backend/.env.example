# ── Required ────────────────────────────────────────────────
# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/stellaredupay

# Stellar wallet address that receives school fee payments
SCHOOL_WALLET_ADDRESS=G...

# ── Stellar Network ──────────────────────────────────────────
# "testnet" (default) or "mainnet"
STELLAR_NETWORK=testnet

# Optional: override the Horizon API URL
# HORIZON_URL=https://horizon-testnet.stellar.org

# Optional: USDC issuer address (defaults to well-known testnet/mainnet issuer)
# USDC_ISSUER=G...

# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── Polling ──────────────────────────────────────────────────
# Background job interval in milliseconds (default: 30000)
POLL_INTERVAL_MS=30000

# ── Retry / Outage Recovery ───────────────────────────────────
# How often the retry worker checks for pending verifications (default: 60000ms = 1 min)
RETRY_INTERVAL_MS=60000

# Maximum number of retry attempts before a transaction is dead-lettered (default: 10)
RETRY_MAX_ATTEMPTS=10

# ── BullMQ Transaction Retry Queue Configuration ───────────────
# Enable/disable BullMQ retry queue
RETRIES_ENABLED=true

# Redis connection for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Maximum retry attempts for failed transactions (default: 10)
MAX_RETRY_ATTEMPTS=10

# Initial retry delay in milliseconds (default: 60000 = 1 minute)
INITIAL_RETRY_DELAY_MS=60000

# Maximum retry delay cap in milliseconds (default: 3600000 = 1 hour)
MAX_RETRY_DELAY_MS=3600000

# Exponential backoff multiplier (default: 2)
RETRY_BACKOFF_MULTIPLIER=2

# Dead Letter Queue settings
DLQ_ENABLED=true
DLQ_MAX_AGE_MS=604800000

# Worker concurrency (default: 5)
QUEUE_CONCURRENCY=5

# Stellar network timeout in milliseconds (default: 10000)
STELLAR_NETWORK_TIMEOUT_MS=10000
